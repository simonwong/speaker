#!/bin/zsh

set -euo pipefail

SCRIPT_DIR="${0:A:h}"
INSTALL_APP="${SPEAKER_INSTALL_APP:-/Applications/Speaker.app}"

case "$INSTALL_APP" in
    /Applications/*.app|"$HOME"/Applications/*.app) ;;
    *)
        print -u2 "Refusing to install outside an Applications directory: $INSTALL_APP"
        exit 1
        ;;
esac

SOURCE_APP="$($SCRIPT_DIR/bundle)"
STAGING_APP="${INSTALL_APP}.installing.$$"

pkill -f -x "$SOURCE_APP/Contents/MacOS/SpeakerApp" 2>/dev/null || true
pkill -f -x "$INSTALL_APP/Contents/MacOS/SpeakerApp" 2>/dev/null || true

trap 'rm -rf "$STAGING_APP"' EXIT
rm -rf "$STAGING_APP"
ditto "$SOURCE_APP" "$STAGING_APP"
codesign --verify --deep --strict "$STAGING_APP"

rm -rf "$INSTALL_APP"
mv "$STAGING_APP" "$INSTALL_APP"
trap - EXIT
rm -rf "$SOURCE_APP"

open "$INSTALL_APP"
print "$INSTALL_APP"
