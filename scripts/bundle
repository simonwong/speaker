#!/bin/zsh

set -euo pipefail

SCRIPT_DIR="${0:A:h}"
ROOT="${SCRIPT_DIR:h}"
CONFIGURATION="${SPEAKER_CONFIGURATION:-debug}"

"$SCRIPT_DIR/build" >&2
BIN_PATH="$("$SCRIPT_DIR/swiftw" build --disable-sandbox --configuration "$CONFIGURATION" --show-bin-path)"
APP="$ROOT/.build/Speaker.app"

mkdir -p "$APP/Contents/MacOS" "$APP/Contents/Resources"
cp "$BIN_PATH/SpeakerApp" "$APP/Contents/MacOS/SpeakerApp"
cp "$ROOT/Resources/Info.plist" "$APP/Contents/Info.plist"
cp "$ROOT/Resources/AppIcon.icns" "$APP/Contents/Resources/AppIcon.icns"
codesign --force --deep --sign - "$APP"
codesign --verify --deep --strict "$APP"

print "$APP"
