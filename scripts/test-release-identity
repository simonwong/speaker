    -t 0 \
    "$SCRIPT_DIR:h/.build/distribution/.release.lock" \
    /bin/sleep 1 &
LOCK_HOLDER_PID=$!
/bin/sleep 0.1
if SPEAKER_DISTRIBUTION_LOCK_HELD=1 \
    /bin/zsh "$SCRIPT_DIR/distribute" >/dev/null 2>&1; then
    wait "$LOCK_HOLDER_PID"
    print -u2 "A concurrent formal release acquired the global lock."
    exit 1
else
    DISTRIBUTE_STATUS=$?
fi
wait "$LOCK_HOLDER_PID"
[[ "$DISTRIBUTE_STATUS" == "75" ]] || {
    print -u2 "Concurrent release returned unexpected status: $DISTRIBUTE_STATUS"
    exit 1
}

