#!/bin/zsh

set -euo pipefail
unsetopt BG_NICE

SCRIPT_DIR="${0:A:h}"
source "$SCRIPT_DIR/release-common"
TEST_ROOT="$(mktemp -d "${TMPDIR:-/tmp}/speaker-release-identity.XXXXXX")"
trap 'chmod -R -P u+w "$TEST_ROOT" 2>/dev/null || true; rm -rf "$TEST_ROOT"' EXIT
mkdir -p "$TEST_ROOT/Resources"

configure_notary_keychain ""
[[ "${#REVIEWED_NOTARY_KEYCHAIN_ARGUMENTS[@]}" == "0" ]]
NOTARY_KEYCHAIN_FIXTURE="$TEST_ROOT/release.keychain-db"
print -r -- fixture > "$NOTARY_KEYCHAIN_FIXTURE"
chmod 600 "$NOTARY_KEYCHAIN_FIXTURE"
configure_notary_keychain "$NOTARY_KEYCHAIN_FIXTURE"
[[ "${#REVIEWED_NOTARY_KEYCHAIN_ARGUMENTS[@]}" == "2" ]]
[[ "$REVIEWED_NOTARY_KEYCHAIN_ARGUMENTS[1]" == "--keychain" ]]
[[ "$REVIEWED_NOTARY_KEYCHAIN_ARGUMENTS[2]" == "$NOTARY_KEYCHAIN_FIXTURE" ]]
chmod 640 "$NOTARY_KEYCHAIN_FIXTURE"
if configure_notary_keychain "$NOTARY_KEYCHAIN_FIXTURE" 2>/dev/null; then
    print -u2 "Group-readable notary Keychain was accepted."
    exit 1
fi
chmod 600 "$NOTARY_KEYCHAIN_FIXTURE"
ln -s "$NOTARY_KEYCHAIN_FIXTURE" "$TEST_ROOT/notary-link.keychain-db"
if configure_notary_keychain "$TEST_ROOT/notary-link.keychain-db" 2>/dev/null; then
    print -u2 "Symlinked notary Keychain was accepted."
    exit 1
fi

write_identity() {
    local bundle_identifier="$1"
    local team_identifier="$2"
    local update_feed_url="$3"
    local update_download_url_prefix="$4"
    local product_url="$5"
    local update_public_ed_key="$6"
    /usr/libexec/PlistBuddy \
        -c 'Clear dict' \
        -c "Add :BundleIdentifier string $bundle_identifier" \
        -c "Add :TeamIdentifier string $team_identifier" \
        -c "Add :UpdateFeedURL string $update_feed_url" \
        -c "Add :UpdateDownloadURLPrefix string $update_download_url_prefix" \
        -c "Add :ProductURL string $product_url" \
        -c "Add :UpdatePublicEDKey string $update_public_ed_key" \
        "$TEST_ROOT/Resources/ReleaseIdentity.plist" >/dev/null
}

write_candidate() {
    local previous_build="$1"
    local version="$2"
    local build_number="$3"
    /usr/libexec/PlistBuddy \
        -c 'Clear dict' \
        -c "Add :PreviousPublishedBuildNumber string $previous_build" \
        -c "Add :Version string $version" \
        -c "Add :BuildNumber string $build_number" \
        "$TEST_ROOT/Resources/ReleaseCandidate.plist" >/dev/null
}

write_identity \
    "REPLACE_WITH_REVIEWED_BUNDLE_ID" \
    "REPLACE_WITH_REVIEWED_TEAM_ID" \
    "https://updates.example.invalid/speaker/appcast.xml" \
    "https://updates.example.invalid/speaker/" \
    "https://speaker.example.invalid/" \
    "REPLACE_WITH_SPARKLE_PUBLIC_ED_KEY"
if load_reviewed_release_identity "$TEST_ROOT" 2>/dev/null; then
    print -u2 "Placeholder release identity was accepted."
    exit 1
fi

write_identity \
    "com.example.speaker" \
    "A1B2C3D4E5" \
    "https://updates.example.com/speaker/appcast.xml" \
    "https://updates.example.com/speaker/" \
    "https://speaker.example.com/" \
    "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
load_reviewed_release_identity "$TEST_ROOT"
[[ "$REVIEWED_RELEASE_BUNDLE_IDENTIFIER" == "com.example.speaker" ]]
[[ "$REVIEWED_RELEASE_TEAM_IDENTIFIER" == "A1B2C3D4E5" ]]
[[ "$REVIEWED_UPDATE_FEED_URL" \
    == "https://updates.example.com/speaker/appcast.xml" ]]
[[ "$REVIEWED_UPDATE_DOWNLOAD_URL_PREFIX" \
    == "https://updates.example.com/speaker/" ]]
[[ "$REVIEWED_PRODUCT_URL" == "https://speaker.example.com/" ]]
[[ "$REVIEWED_UPDATE_PUBLIC_ED_KEY" \
    == "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=" ]]

write_candidate \
    "0" \
    "REPLACE_WITH_REVIEWED_VERSION" \
    "REPLACE_WITH_REVIEWED_BUILD_NUMBER"
if load_reviewed_release_candidate "$TEST_ROOT" 2>/dev/null; then
    print -u2 "Placeholder release candidate was accepted."
    exit 1
fi
write_candidate "41" "1.2.3" "42"
load_reviewed_release_candidate "$TEST_ROOT"
[[ "$REVIEWED_PREVIOUS_PUBLISHED_BUILD_NUMBER" == "41" ]]
[[ "$REVIEWED_RELEASE_VERSION" == "1.2.3" ]]
[[ "$REVIEWED_RELEASE_BUILD_NUMBER" == "42" ]]
reject_release_candidate_override "1.2.3" "42"
if reject_release_candidate_override "1.2.3" "41" 2>/dev/null; then
    print -u2 "A CI build override bypassed the reviewed candidate."
    exit 1
fi
write_candidate "42" "1.2.4" "42"
if load_reviewed_release_candidate "$TEST_ROOT" 2>/dev/null; then
    print -u2 "A reused published build number was accepted."
    exit 1
fi
write_candidate "42" "1.2.4" "43"
load_reviewed_release_candidate "$TEST_ROOT"

TEST_APP="$TEST_ROOT/Speaker.app"
TEST_INFO="$TEST_APP/Contents/Info.plist"
TEST_BUILD_MANIFEST="$TEST_APP/Contents/Resources/BuildManifest.plist"
mkdir -p "$TEST_APP/Contents/Resources"
/usr/libexec/PlistBuddy \
    -c 'Clear dict' \
    -c 'Add :SpeakerSigningMode string developer-id' \
    -c 'Add :SpeakerCredentialStorage string keychain' \
    -c 'Add :SpeakerKeychainService string com.example.speaker.provider-api-keys' \
    -c 'Add :SUFeedURL string https://updates.example.com/speaker/appcast.xml' \
    -c 'Add :SUPublicEDKey string AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=' \
    -c 'Add :SUVerifyUpdateBeforeExtraction bool true' \
    -c 'Add :SURequireSignedFeed bool true' \
    -c 'Add :SUSignedFeedFailureExpirationInterval integer 0' \
    -c 'Add :SUEnableAutomaticChecks bool false' \
    -c 'Add :SUAutomaticallyUpdate bool false' \
    -c 'Add :SUEnableSystemProfiling bool false' \
    -c 'Add :SUEnableJavaScript bool false' \
    "$TEST_INFO" >/dev/null
verify_production_update_configuration \
    "$TEST_APP" \
    "com.example.speaker" \
    "https://updates.example.com/speaker/appcast.xml" \
    "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
/usr/libexec/PlistBuddy \
    -c 'Set :SUPublicEDKey BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB=' \
    "$TEST_INFO"
if verify_production_update_configuration \
    "$TEST_APP" \
    "com.example.speaker" \
    "https://updates.example.com/speaker/appcast.xml" \
    "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=" 2>/dev/null; then
    print -u2 "A production app with an unreviewed update key was accepted."
    exit 1
fi

SOURCE_COMMIT="$(printf 'a%.0s' {1..40})"
PACKAGE_HASH="$(printf 'b%.0s' {1..64})"
NOTES_HASH="$(printf 'c%.0s' {1..64})"
/usr/libexec/PlistBuddy \
    -c 'Clear dict' \
    -c 'Add :SchemaVersion integer 1' \
    -c "Add :SourceCommit string $SOURCE_COMMIT" \
    -c "Add :PackageResolvedSHA256 string $PACKAGE_HASH" \
    -c "Add :ReleaseNotesSHA256 string $NOTES_HASH" \
    -c 'Add :Version string 1.2.3' \
    -c 'Add :BuildNumber string 42' \
    "$TEST_BUILD_MANIFEST" >/dev/null
verify_production_build_provenance \
    "$TEST_APP" \
    "$SOURCE_COMMIT" \
    "$PACKAGE_HASH" \
    "$NOTES_HASH" \
    "1.2.3" \
    "42"
verify_production_build_provenance_shape "$TEST_APP" "1.2.3" "42"
/usr/libexec/PlistBuddy \
    -c "Set :ReleaseNotesSHA256 $(printf 'd%.0s' {1..64})" \
    "$TEST_BUILD_MANIFEST"
if verify_production_build_provenance \
    "$TEST_APP" \
    "$SOURCE_COMMIT" \
    "$PACKAGE_HASH" \
    "$NOTES_HASH" \
    "1.2.3" \
    "42" 2>/dev/null; then
    print -u2 "A build manifest with different release notes was accepted."
    exit 1
fi

NOTARY_RESULT="$TEST_ROOT/notary-result.json"
NOTARY_LOG="$TEST_ROOT/notary-log.json"
print -r -- \
    '{"id":"12345678-1234-1234-1234-123456789abc","status":"Accepted"}' \
    > "$NOTARY_RESULT"
print -r -- \
    '{"jobId":"12345678-1234-1234-1234-123456789abc","status":"Accepted","archiveFilename":"submission.zip","sha256":"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa","issues":[]}' \
    > "$NOTARY_LOG"
validate_notary_submission_result "$NOTARY_RESULT"
[[ "$REVIEWED_NOTARY_SUBMISSION_ID" \
    == "12345678-1234-1234-1234-123456789abc" ]]
validate_notary_log \
    "$NOTARY_LOG" \
    "$REVIEWED_NOTARY_SUBMISSION_ID" \
    "$(printf 'a%.0s' {1..64})" \
    "submission.zip"
if validate_notary_log \
    "$NOTARY_LOG" \
    "$REVIEWED_NOTARY_SUBMISSION_ID" \
    "$(printf 'b%.0s' {1..64})" \
    "submission.zip" 2>/dev/null; then
    print -u2 "A notarization log for different submitted bytes was accepted."
    exit 1
fi
print -r -- \
    '{"id":"12345678-1234-1234-1234-123456789abc","status":"Invalid"}' \
    > "$NOTARY_RESULT"
if validate_notary_submission_result "$NOTARY_RESULT" 2>/dev/null; then
    print -u2 "An invalid notarization result was accepted."
    exit 1
fi

EVIDENCE_FIXTURE_DIR="$TEST_ROOT/evidence-fixture"
EVIDENCE_FIXTURE_ZIP="$TEST_ROOT/evidence-fixture.zip"
mkdir "$EVIDENCE_FIXTURE_DIR"
APP_SUBMISSION_ID="12345678-1234-1234-1234-123456789abc"
DMG_SUBMISSION_ID="abcdefab-cdef-cdef-cdef-abcdefabcdef"
APP_SUBMISSION_HASH="$(printf 'a%.0s' {1..64})"
DMG_SUBMISSION_HASH="$(printf 'b%.0s' {1..64})"
DMG_HASH="$(printf 'c%.0s' {1..64})"
APPCAST_HASH="$(printf 'd%.0s' {1..64})"
SDK_SETTINGS_HASH="$(printf 'e%.0s' {1..64})"
EVIDENCE_MANIFEST="$EVIDENCE_FIXTURE_DIR/ReleaseManifest.plist"
PROVIDER_EVIDENCE_HASH="$(printf 'f%.0s' {1..64})"
plutil -create xml1 "$EVIDENCE_MANIFEST"
plutil -insert SchemaVersion -integer 2 "$EVIDENCE_MANIFEST"
for pair in \
    'Version|1.2.3' \
    'BuildNumber|42' \
    'DMGBasename|Speaker-1.2.3-42.dmg' \
    "DMGSHA256|$DMG_HASH" \
    "AppcastSHA256|$APPCAST_HASH" \
    "AppSubmissionSHA256|$APP_SUBMISSION_HASH" \
    "DMGSubmissionSHA256|$DMG_SUBMISSION_HASH" \
    "AppNotarySubmissionID|$APP_SUBMISSION_ID" \
    "DMGNotarySubmissionID|$DMG_SUBMISSION_ID" \
    "SourceCommit|$SOURCE_COMMIT" \
    "PackageResolvedSHA256|$PACKAGE_HASH" \
    "ReleaseNotesSHA256|$(printf 'd%.0s' {1..64})" \
    "ProviderEvidenceSHA256|$PROVIDER_EVIDENCE_HASH" \
    'SDKCanonicalName|macosx26.0' \
    "SDKSettingsSHA256|$SDK_SETTINGS_HASH"; do
    plutil -insert "${pair%%|*}" -string "${pair#*|}" \
        "$EVIDENCE_MANIFEST"
done
cp "$TEST_BUILD_MANIFEST" "$EVIDENCE_FIXTURE_DIR/BuildManifest.plist"
mkdir "$EVIDENCE_FIXTURE_DIR/dsym-content"
print -r -- dwarf > "$EVIDENCE_FIXTURE_DIR/dsym-content/debug-info"
ditto -c -k \
    "$EVIDENCE_FIXTURE_DIR/dsym-content" \
    "$EVIDENCE_FIXTURE_DIR/Speaker.app.dSYM.zip"
rm -rf "$EVIDENCE_FIXTURE_DIR/dsym-content"
print -r -- \
    "{\"id\":\"$APP_SUBMISSION_ID\",\"status\":\"Accepted\"}" \
    > "$EVIDENCE_FIXTURE_DIR/app-notary-submission.json"
print -r -- \
    "{\"jobId\":\"$APP_SUBMISSION_ID\",\"status\":\"Accepted\",\"archiveFilename\":\"submission.zip\",\"sha256\":\"$APP_SUBMISSION_HASH\"}" \
    > "$EVIDENCE_FIXTURE_DIR/app-notary-log.json"
print -r -- \
    "{\"id\":\"$DMG_SUBMISSION_ID\",\"status\":\"Accepted\"}" \
    > "$EVIDENCE_FIXTURE_DIR/dmg-notary-submission.json"
print -r -- \
    "{\"jobId\":\"$DMG_SUBMISSION_ID\",\"status\":\"Accepted\",\"archiveFilename\":\"final.dmg\",\"sha256\":\"$DMG_SUBMISSION_HASH\"}" \
    > "$EVIDENCE_FIXTURE_DIR/dmg-notary-log.json"
print -r -- 'Swift version fixture' \
    > "$EVIDENCE_FIXTURE_DIR/swift-version.txt"
print -r -- 'ProductName: macOS' \
    > "$EVIDENCE_FIXTURE_DIR/macos-version.txt"
print -r -- '/Applications/Xcode.app/SDKs/MacOSX.sdk' \
    > "$EVIDENCE_FIXTURE_DIR/sdk-path.txt"
print -r -- 'macosx26.0' \
    > "$EVIDENCE_FIXTURE_DIR/sdk-version.txt"
print -r -- "$SDK_SETTINGS_HASH" \
    > "$EVIDENCE_FIXTURE_DIR/sdk-settings-sha256.txt"
print -rn -- provider-matrix-fixture \
    > "$EVIDENCE_FIXTURE_DIR/provider-matrix.json"
PROVIDER_EVIDENCE_HASH="$(
    shasum -a 256 "$EVIDENCE_FIXTURE_DIR/provider-matrix.json" | awk '{print $1}'
)"
plutil -replace ProviderEvidenceSHA256 \
    -string "$PROVIDER_EVIDENCE_HASH" \
    "$EVIDENCE_MANIFEST"
ditto -c -k "$EVIDENCE_FIXTURE_DIR" "$EVIDENCE_FIXTURE_ZIP"
validate_release_evidence_archive \
    "$EVIDENCE_FIXTURE_ZIP" \
    "1.2.3" \
    "42" \
    "Speaker-1.2.3-42.dmg" \
    "$DMG_HASH" \
    "$APPCAST_HASH" \
    "$APP_SUBMISSION_HASH" \
    "$DMG_SUBMISSION_HASH" \
    "$APP_SUBMISSION_ID" \
    "$DMG_SUBMISSION_ID"
print -rn -- tampered-provider-matrix \
    > "$EVIDENCE_FIXTURE_DIR/provider-matrix.json"
rm -f "$EVIDENCE_FIXTURE_ZIP"
ditto -c -k "$EVIDENCE_FIXTURE_DIR" "$EVIDENCE_FIXTURE_ZIP"
if validate_release_evidence_archive \
    "$EVIDENCE_FIXTURE_ZIP" \
    "1.2.3" \
    "42" \
    "Speaker-1.2.3-42.dmg" \
    "$DMG_HASH" \
    "$APPCAST_HASH" \
    "$APP_SUBMISSION_HASH" \
    "$DMG_SUBMISSION_HASH" \
    "$APP_SUBMISSION_ID" \
    "$DMG_SUBMISSION_ID" 2>/dev/null; then
    print -u2 "Tampered provider evidence was accepted."
    exit 1
fi
print -rn -- provider-matrix-fixture \
    > "$EVIDENCE_FIXTURE_DIR/provider-matrix.json"
rm -f "$EVIDENCE_FIXTURE_ZIP"
ditto -c -k "$EVIDENCE_FIXTURE_DIR" "$EVIDENCE_FIXTURE_ZIP"
if validate_release_evidence_archive \
    "$EVIDENCE_FIXTURE_ZIP" \
    "1.2.4" \
    "42" \
    "Speaker-1.2.3-42.dmg" \
    "$DMG_HASH" \
    "$APPCAST_HASH" \
    "$APP_SUBMISSION_HASH" \
    "$DMG_SUBMISSION_HASH" \
    "$APP_SUBMISSION_ID" \
    "$DMG_SUBMISSION_ID" 2>/dev/null; then
    print -u2 "Evidence for a different release version was accepted."
    exit 1
fi
print -r -- 'must-not-be-published' \
    > "$EVIDENCE_FIXTURE_DIR/unexpected-secret.txt"
rm -f "$EVIDENCE_FIXTURE_ZIP"
ditto -c -k "$EVIDENCE_FIXTURE_DIR" "$EVIDENCE_FIXTURE_ZIP"
if validate_release_evidence_archive \
    "$EVIDENCE_FIXTURE_ZIP" \
    "1.2.3" \
    "42" \
    "Speaker-1.2.3-42.dmg" \
    "$DMG_HASH" \
    "$APPCAST_HASH" \
    "$APP_SUBMISSION_HASH" \
    "$DMG_SUBMISSION_HASH" \
    "$APP_SUBMISSION_ID" \
    "$DMG_SUBMISSION_ID" 2>/dev/null; then
    print -u2 "Evidence with an unexpected private entry was accepted."
    exit 1
fi
rm -f "$EVIDENCE_FIXTURE_DIR/unexpected-secret.txt"
print -r -- "$(printf 'f%.0s' {1..64})" \
    > "$EVIDENCE_FIXTURE_DIR/sdk-settings-sha256.txt"
rm -f "$EVIDENCE_FIXTURE_ZIP"
ditto -c -k "$EVIDENCE_FIXTURE_DIR" "$EVIDENCE_FIXTURE_ZIP"
if validate_release_evidence_archive \
    "$EVIDENCE_FIXTURE_ZIP" \
    "1.2.3" \
    "42" \
    "Speaker-1.2.3-42.dmg" \
    "$DMG_HASH" \
    "$APPCAST_HASH" \
    "$APP_SUBMISSION_HASH" \
    "$DMG_SUBMISSION_HASH" \
    "$APP_SUBMISSION_ID" \
    "$DMG_SUBMISSION_ID" 2>/dev/null; then
    print -u2 "Evidence whose SDK record disagrees with its manifest was accepted."
    exit 1
fi
print -r -- "$SDK_SETTINGS_HASH" \
    > "$EVIDENCE_FIXTURE_DIR/sdk-settings-sha256.txt"
rm -f "$EVIDENCE_FIXTURE_DIR/sdk-version.txt" "$EVIDENCE_FIXTURE_ZIP"
ditto -c -k "$EVIDENCE_FIXTURE_DIR" "$EVIDENCE_FIXTURE_ZIP"
if validate_release_evidence_archive \
    "$EVIDENCE_FIXTURE_ZIP" \
    "1.2.3" \
    "42" \
    "Speaker-1.2.3-42.dmg" \
    "$DMG_HASH" \
    "$APPCAST_HASH" \
    "$APP_SUBMISSION_HASH" \
    "$DMG_SUBMISSION_HASH" \
    "$APP_SUBMISSION_ID" \
    "$DMG_SUBMISSION_ID" 2>/dev/null; then
    print -u2 "An incomplete release evidence archive was accepted."
    exit 1
fi

write_identity \
    "com.example.speaker" \
    "A1B2C3D4E5" \
    "http://updates.example.com/speaker/appcast.xml" \
    "https://updates.example.com/speaker/" \
    "https://speaker.example.com/" \
    "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
if load_reviewed_release_identity "$TEST_ROOT" 2>/dev/null; then
    print -u2 "An insecure update feed URL was accepted."
    exit 1
fi

write_identity \
    "com.example.speaker" \
    "A1B2C3D4E5" \
    "https://updates.example.com/speaker/appcast.xml" \
    "https://downloads.example.com/speaker/" \
    "https://speaker.example.com/" \
    "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
if load_reviewed_release_identity "$TEST_ROOT" 2>/dev/null; then
    print -u2 "A mismatched update download prefix was accepted."
    exit 1
fi

write_identity \
    "com.example.speaker" \
    "A1B2C3D4E5" \
    "https://updates.example.com/speaker/appcast.xml" \
    "https://updates.example.com/speaker/" \
    "http://speaker.example.com/" \
    "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
if load_reviewed_release_identity "$TEST_ROOT" 2>/dev/null; then
    print -u2 "An insecure product URL was accepted."
    exit 1
fi

write_identity \
    "com.example.speaker" \
    "A1B2C3D4E5" \
    "https://updates.example.com/speaker/appcast.xml" \
    "https://updates.example.com/speaker/" \
    "https://speaker.example.com/" \
    "dG9vLXNob3J0"
if load_reviewed_release_identity "$TEST_ROOT" 2>/dev/null; then
    print -u2 "An invalid Sparkle public key was accepted."
    exit 1
fi

write_identity \
    "com.example.speaker" \
    "A1B2C3D4E5" \
    "https://updates.example.com/speaker/appcast.xml" \
    "https://updates.example.com/speaker/" \
    "https://speaker.example.com/" \
    "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="

if reject_release_identity_override \
    "com.attacker.speaker" \
    "A1B2C3D4E5" 2>/dev/null; then
    print -u2 "Bundle identity override was accepted."
    exit 1
fi
if reject_release_identity_override \
    "com.example.speaker" \
    "ZZZZZZZZZZ" 2>/dev/null; then
    print -u2 "Team identity override was accepted."
    exit 1
fi
reject_release_identity_override \
    "com.example.speaker" \
    "A1B2C3D4E5"

SINGLE_LOCAL='
  1) ABCDEF1234 "Speaker Local Development"
     1 valid identities found
'
[[ "$(select_local_signing_identity "$SINGLE_LOCAL")" \
    == "Speaker Local Development" ]]

SINGLE_APPLE='
  1) ABCDEF1234 "Apple Development: Speaker Developer (A1B2C3D4E5)"
     1 valid identities found
'
[[ "$(select_local_signing_identity "$SINGLE_APPLE")" \
    == "Apple Development: Speaker Developer (A1B2C3D4E5)" ]]

PREFERRED_OVER_APPLE='
  1) ABCDEF1234 "Apple Development: Speaker Developer (A1B2C3D4E5)"
  2) FEDCBA4321 "Speaker Local Development"
     2 valid identities found
'
[[ "$(select_local_signing_identity "$PREFERRED_OVER_APPLE")" \
    == "Speaker Local Development" ]]

AMBIGUOUS_APPLE='
  1) ABCDEF1234 "Apple Development: First (A1B2C3D4E5)"
  2) FEDCBA4321 "Apple Development: Second (Z9Y8X7W6V5)"
     2 valid identities found
'
if select_local_signing_identity "$AMBIGUOUS_APPLE" 2>/dev/null; then
    print -u2 "Ambiguous Apple Development identities were auto-selected."
    exit 1
else
    [[ "$?" == 2 ]]
fi

for version in \
    "1.2.3" \
    "1.2.3-beta.1" \
    "1.2.3+reviewed.1" \
    "1.2.3-beta.1+reviewed.1"; do
    validate_bundle_metadata "$version" "42" "com.example.speaker"
    basename="Speaker-$version-42.dmg"
    checksum="$(printf 'a%.0s' {1..64})  $basename"
validate_portable_checksum_line "$checksum" "$basename"
done
if validate_production_metadata \
    "1.2.3-beta.1" \
    "43" \
    "com.example.speaker" \
    "A1B2C3D4E5" 2>/dev/null; then
    print -u2 "A prerelease without a reviewed update channel was accepted."
    exit 1
fi
validate_production_metadata \
    "1.2.3+reviewed-build.1" \
    "44" \
    "com.example.speaker" \
    "A1B2C3D4E5"
if validate_portable_checksum_line \
    "$(printf 'a%.0s' {1..64})  Speaker-1X2X3-42.dmg" \
    "Speaker-1.2.3-42.dmg" 2>/dev/null; then
    print -u2 "A checksum for a different artifact basename was accepted."
    exit 1
fi

APPCAST_FIXTURE="$TEST_ROOT/appcast.xml"
print -r -- '<?xml version="1.0" encoding="utf-8"?>
<rss xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle">
  <channel>
    <item><sparkle:version>9</sparkle:version></item>
    <item><sparkle:version>10</sparkle:version></item>
  </channel>
</rss>' > "$APPCAST_FIXTURE"
validate_appcast_build_order "11" "$APPCAST_FIXTURE" strictly-newer
validate_appcast_build_order "10" "$APPCAST_FIXTURE" latest
if validate_appcast_build_order \
    "10" \
    "$APPCAST_FIXTURE" \
    strictly-newer 2>/dev/null; then
    print -u2 "A reused appcast build number was accepted."
    exit 1
fi
if validate_appcast_build_order \
    "9" \
    "$APPCAST_FIXTURE" \
    latest 2>/dev/null; then
    print -u2 "A non-latest published build was accepted."
    exit 1
fi
release_build_is_greater \
    "100000000000000000000000000000000000000" \
    "99999999999999999999999999999999999999"

