#!/bin/zsh

set -euo pipefail

ROOT="${0:A:h:h}"
DEFAULT_SDK="/Library/Developer/CommandLineTools/SDKs/MacOSX26.sdk"
if [[ -n "${SPEAKER_SDKROOT:-}" ]]; then
    SDK="$SPEAKER_SDKROOT"
elif [[ -d "$DEFAULT_SDK" ]]; then
    # This repository currently targets the CLT version used for local
    # verification. CI may pin SPEAKER_SDKROOT explicitly.
    SDK="$DEFAULT_SDK"
else
    SDK="$(xcrun --sdk macosx --show-sdk-path)"
fi
SDK="${SDK:A}"
if [[ "${1:-}" == "--print-sdk-path" ]]; then
    print -r -- "$SDK"
    exit 0
fi
DEFAULT_CACHE_ROOT="${TMPDIR:-/tmp}/speaker-swift-cache-${UID}"
CACHE_ROOT="${SPEAKER_CACHE_ROOT:-$DEFAULT_CACHE_ROOT}"

if [[ -L "$CACHE_ROOT" ]]; then
    print -u2 "Refusing a symlinked Swift build cache: $CACHE_ROOT"
    exit 1
fi
mkdir -p "$CACHE_ROOT/swiftpm" "$CACHE_ROOT/clang"
chmod 700 "$CACHE_ROOT" "$CACHE_ROOT/swiftpm" "$CACHE_ROOT/clang"

export SDKROOT="$SDK"
export SWIFTPM_MODULECACHE_OVERRIDE="$CACHE_ROOT/swiftpm"
export CLANG_MODULE_CACHE_PATH="$CACHE_ROOT/clang"

cd "$ROOT"
if [[ "${SPEAKER_SWIFT_RELEASE_ISOLATION:-0}" == "1" \
      && -z "${SPEAKER_SWIFT_SCRATCH_PATH:-}" ]]; then
    print -u2 "Release isolation requires SPEAKER_SWIFT_SCRATCH_PATH."
    exit 1
fi
if [[ -n "${SPEAKER_SWIFT_SCRATCH_PATH:-}" ]]; then
    SCRATCH_PATH="$SPEAKER_SWIFT_SCRATCH_PATH"
    if [[ "$SCRATCH_PATH" != /* \
          || "$SCRATCH_PATH" == */./* \
          || "$SCRATCH_PATH" == */../* \
          || "$SCRATCH_PATH" == */. \
          || "$SCRATCH_PATH" == */.. ]]; then
        print -u2 "SPEAKER_SWIFT_SCRATCH_PATH must be an absolute normalized path."
        exit 1
    fi
    CURRENT_COMPONENT=""
    for COMPONENT in ${(s:/:)SCRATCH_PATH}; do
        [[ -n "$COMPONENT" ]] || continue
        CURRENT_COMPONENT="$CURRENT_COMPONENT/$COMPONENT"
        if [[ -L "$CURRENT_COMPONENT" ]]; then
            print -u2 "Refusing a symlinked Swift scratch path: $CURRENT_COMPONENT"
            exit 1
        fi
    done
    (( $# > 0 )) || {
        print -u2 "A Swift subcommand is required when using an isolated scratch path."
        exit 1
    }
    SWIFT_SUBCOMMAND="$1"
    shift
    RELEASE_RESOLUTION_ARGUMENTS=()
    if [[ "${SPEAKER_SWIFT_RELEASE_ISOLATION:-0}" == "1" ]]; then
        RELEASE_RESOLUTION_ARGUMENTS=(
            --disable-keychain
            --disable-netrc
            --only-use-versions-from-resolved-file
        )
    fi
    case "$SWIFT_SUBCOMMAND" in
        build|run|test)
            exec swift "$SWIFT_SUBCOMMAND" \
                --scratch-path "$SCRATCH_PATH" \
                "${RELEASE_RESOLUTION_ARGUMENTS[@]}" \
                "$@"
            ;;
        *)
            print -u2 "Isolated Swift scratch paths are not supported for: $SWIFT_SUBCOMMAND"
            exit 1
            ;;
    esac
fi
exec swift "$@"
