#!/bin/zsh

# Shared fail-closed validation for Speaker's packaging scripts.
# This file is sourced by bundle/install/distribute and must not change shell
# options or terminate the caller directly.

release_error() {
    print -u2 -- "$*"
    return 1
}

configure_notary_keychain() {
    local requested_path="${1:-}"
    local mode

    typeset -ga REVIEWED_NOTARY_KEYCHAIN_ARGUMENTS=()
    [[ -n "$requested_path" ]] || return 0
    if [[ ! -f "$requested_path" || -L "$requested_path" \
          || "$(stat -f %u "$requested_path")" != "$UID" ]]; then
        release_error "Notary Keychain must be an owner-controlled regular file."
        return 1
    fi
    mode="$(stat -f %Lp "$requested_path")" || return 1
    if (( (8#$mode & 8#077) != 0 )); then
        release_error "Notary Keychain must not be accessible by group or other users."
        return 1
    fi
    REVIEWED_NOTARY_KEYCHAIN_ARGUMENTS=(
        --keychain
        "$requested_path"
    )
}

verify_release_source_tree_clean() {
    local root="$1"
    local tree_status

    if ! git -C "$root" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        release_error "Formal releases require a Git source checkout."
        return 1
    fi
    tree_status="$(git -C "$root" status --porcelain --untracked-files=all)" || {
        release_error "Unable to inspect the release source tree."
        return 1
    }
    if [[ -n "$tree_status" ]]; then
        release_error "Formal releases require a clean source tree with no untracked files."
        return 1
    fi
}

resolve_tracked_release_notes() {
    local root="$1"
    local requested_path="$2"
    local canonical_root
    local absolute_path
    local relative_path

    if [[ ! -f "$requested_path" || -L "$requested_path" \
          || ! -s "$requested_path" ]]; then
        release_error "Release notes must be a non-empty regular file."
        return 1
    fi
    canonical_root="${root:A}"
    absolute_path="${requested_path:A}"
    if [[ "$absolute_path" != "$canonical_root/"* ]]; then
        release_error "Release notes must be committed inside the release repository."
        return 1
    fi
    relative_path="${absolute_path#$canonical_root/}"
    if ! git -C "$canonical_root" ls-files --error-unmatch -- "$relative_path" \
        >/dev/null 2>&1; then
        release_error "Release notes must be tracked by Git: $relative_path"
        return 1
    fi
    typeset -g REVIEWED_RELEASE_NOTES_RELATIVE_PATH="$relative_path"
}

create_release_source_snapshot() {
    local root="$1"
    local destination="$2"
    local parent="${destination:h}"
    local archive="$parent/source-snapshot.tar"
    local commit

    if [[ -e "$destination" || -L "$destination" \
          || ! -d "$parent" || -L "$parent" \
          || "$(stat -f %u "$parent")" != "$UID" \
          || "$(stat -f %Lp "$parent")" != "700" ]]; then
        release_error "Release source snapshot requires a fresh owner-only pending directory."
        return 1
    fi
    commit="$(git -C "$root" rev-parse --verify 'HEAD^{commit}')" || return 1
    if ! matches_release_pattern "$commit" '^[0-9a-f]{40}$'; then
        release_error "Unable to resolve the release source commit."
        return 1
    fi
    git -C "$root" archive \
        --format=tar \
        --output="$archive" \
        "$commit"
    mkdir "$destination"
    chmod 700 "$destination"
    /usr/bin/tar -xf "$archive" -C "$destination"
    rm -f "$archive"
    chmod -R -P a-w "$destination"
    typeset -g REVIEWED_RELEASE_SOURCE_COMMIT="$commit"
}

verify_swiftpm_dependency_checkouts_clean() {
    local root="$1"
    local checkout checkout_status
    local -a checkouts

    checkouts=("$root/.build/checkouts"/*(N/))
    for checkout in "${checkouts[@]}"; do
        if ! git -C "$checkout" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
            release_error "SwiftPM dependency is not a verifiable Git checkout: $checkout"
            return 1
        fi
        checkout_status="$(git -C "$checkout" status --porcelain --untracked-files=all)" || {
            release_error "Unable to inspect SwiftPM dependency checkout: $checkout"
            return 1
        }
        if [[ -n "$checkout_status" ]]; then
            release_error "SwiftPM dependency checkout contains local changes: ${checkout:t}"
            return 1
        fi
    done
}

select_local_signing_identity() {
    local identity_output="$1"
    local name
    local -a names preferred apple_development

    names=("${(@f)$(
        print -r -- "$identity_output" \
            | sed -nE 's/^[[:space:]]*[0-9]+\) [0-9A-Fa-f]+ "([^"]+)".*$/\1/p'
    )}")
    for name in "${names[@]}"; do
        [[ -n "$name" ]] || continue
        if [[ "$name" == "Speaker Local Development" ]]; then
            preferred+=("$name")
        elif [[ "$name" == "Apple Development: "* ]]; then
            apple_development+=("$name")
        fi
    done

    if (( ${#preferred} == 1 )); then
        print -r -- "$preferred[1]"
        return 0
    fi
    if (( ${#preferred} > 1 )); then
        release_error "Multiple Speaker Local Development identities are available; set SPEAKER_LOCAL_CODESIGN_IDENTITY explicitly."
        return 2
    fi
    if (( ${#apple_development} == 1 )); then
        print -r -- "$apple_development[1]"
        return 0
    fi
    if (( ${#apple_development} > 1 )); then
        release_error "Multiple Apple Development identities are available; set SPEAKER_LOCAL_CODESIGN_IDENTITY explicitly."
        return 2
    fi
    return 1
}

matches_release_pattern() {
    local value="$1"
    local pattern="$2"
    LC_ALL=C grep -Eq -- "$pattern" <<< "$value"
}

validate_portable_checksum_line() {
    local line="$1"
    local expected_basename="$2"
    local hash="${line%%  *}"

    if ! matches_release_pattern "$hash" '^[0-9a-f]{64}$' \
          || [[ "$line" != "$hash  $expected_basename" ]]; then
        release_error "Checksum must contain one lowercase SHA-256 and the exact artifact basename."
        return 1
    fi
}

release_build_is_greater() {
    local candidate="$1"
    local baseline="$2"

    matches_release_pattern "$candidate" '^[1-9][0-9]*$' || return 2
    matches_release_pattern "$baseline" '^[1-9][0-9]*$' || return 2
    if (( ${#candidate} != ${#baseline} )); then
        (( ${#candidate} > ${#baseline} ))
        return
    fi
    [[ "$candidate" > "$baseline" ]]
}

validate_appcast_build_order() {
    local candidate="$1"
    local appcast="$2"
    local mode="$3"
    local xpath="//*[local-name()='item']/*[local-name()='version']"
    local count
    local index
    local existing

    [[ "$mode" == strictly-newer || "$mode" == latest ]] || return 2
    matches_release_pattern "$candidate" '^[1-9][0-9]*$' || return 2
    xmllint --noout "$appcast" || return 1
    count="$(xmllint --xpath "count($xpath)" "$appcast")" || return 1
    matches_release_pattern "$count" '^[0-9]+$' || return 1
    for (( index = 1; index <= count; index++ )); do
        existing="$(
            xmllint \
                --xpath "string(($xpath)[$index])" \
                "$appcast"
        )" || return 1
        if ! matches_release_pattern "$existing" '^[1-9][0-9]*$'; then
            release_error "Appcast contains an invalid build number: $existing"
            return 1
        fi
        if [[ "$mode" == strictly-newer ]]; then
            if ! release_build_is_greater "$candidate" "$existing"; then
                release_error "Build $candidate is not newer than appcast build $existing."
                return 1
            fi
        elif release_build_is_greater "$existing" "$candidate"; then
            release_error "Appcast build $existing is newer than requested build $candidate."
            return 1
        fi
    done
}

validate_bundle_metadata() {
    local version="$1"
    local build_number="$2"
    local bundle_identifier="$3"
    local semver_pattern='^(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)(-((0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*)(\.(0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*))*))?(\+[0-9A-Za-z-]+(\.[0-9A-Za-z-]+)*)?$'
    local bundle_pattern='^[A-Za-z][A-Za-z0-9]*(-[A-Za-z0-9]+)*(\.[A-Za-z0-9]+(-[A-Za-z0-9]+)*){2,}$'

    if ! matches_release_pattern "$version" "$semver_pattern"; then
        release_error "Invalid semantic version: $version"
        return 1
    fi
    if ! matches_release_pattern "$build_number" '^[1-9][0-9]*$'; then
        release_error "Build number must be a positive integer: $build_number"
        return 1
    fi
    if ! matches_release_pattern "$bundle_identifier" "$bundle_pattern"; then
        release_error "Bundle identifier must be a reverse-DNS identifier: $bundle_identifier"
        return 1
    fi
}

validate_production_metadata() {
    local version="$1"
    local build_number="$2"
    local bundle_identifier="$3"
    local expected_team_id="$4"
    local version_without_build_metadata="${version%%+*}"

    validate_bundle_metadata "$version" "$build_number" "$bundle_identifier" || return 1
    if [[ "$version_without_build_metadata" == *-* ]]; then
        release_error "Prerelease versions require a reviewed Sparkle channel; stable production releases cannot use: $version"
        return 1
    fi
    if [[ "$bundle_identifier" == com.local.* ]]; then
        release_error "Production bundle identifier must not use com.local: $bundle_identifier"
        return 1
    fi
    if ! matches_release_pattern "$expected_team_id" '^[A-Z0-9]{10}$'; then
        release_error "SPEAKER_EXPECTED_TEAM_ID must be a 10-character Apple Team ID."
        return 1
    fi
}

load_reviewed_release_identity() {
    local root="$1"
    local identity_file="$root/Resources/ReleaseIdentity.plist"
    local bundle_identifier
    local team_identifier
    local update_feed_url
    local update_download_url_prefix
    local product_url
    local update_public_ed_key
    local decoded_key
    local decoded_key_size

    if [[ ! -f "$identity_file" || -L "$identity_file" ]]; then
        release_error "Reviewed release identity is missing: $identity_file"
        return 1
    fi
    if ! plutil -lint "$identity_file" >/dev/null; then
        release_error "Reviewed release identity is not a valid property list."
        return 1
    fi
    bundle_identifier="$(
        /usr/libexec/PlistBuddy \
            -c 'Print :BundleIdentifier' \
            "$identity_file" 2>/dev/null
    )" || {
        release_error "ReleaseIdentity.plist is missing BundleIdentifier."
        return 1
    }
    team_identifier="$(
        /usr/libexec/PlistBuddy \
            -c 'Print :TeamIdentifier' \
            "$identity_file" 2>/dev/null
    )" || {
        release_error "ReleaseIdentity.plist is missing TeamIdentifier."
        return 1
    }
    update_feed_url="$(
        /usr/libexec/PlistBuddy \
            -c 'Print :UpdateFeedURL' \
            "$identity_file" 2>/dev/null
    )" || {
        release_error "ReleaseIdentity.plist is missing UpdateFeedURL."
        return 1
    }
    update_public_ed_key="$(
        /usr/libexec/PlistBuddy \
            -c 'Print :UpdatePublicEDKey' \
            "$identity_file" 2>/dev/null
    )" || {
        release_error "ReleaseIdentity.plist is missing UpdatePublicEDKey."
        return 1
    }
    update_download_url_prefix="$(
        /usr/libexec/PlistBuddy \
            -c 'Print :UpdateDownloadURLPrefix' \
            "$identity_file" 2>/dev/null
    )" || {
        release_error "ReleaseIdentity.plist is missing UpdateDownloadURLPrefix."
        return 1
    }
    product_url="$(
        /usr/libexec/PlistBuddy \
            -c 'Print :ProductURL' \
            "$identity_file" 2>/dev/null
    )" || {
        release_error "ReleaseIdentity.plist is missing ProductURL."
        return 1
    }
    if [[ "$bundle_identifier" == REPLACE_* \
          || "$team_identifier" == REPLACE_* \
          || "$update_public_ed_key" == REPLACE_* ]]; then
        release_error "Formal release and update identity has not been configured and reviewed."
        return 1
    fi
    validate_production_metadata \
        "1.0.0" \
        "1" \
        "$bundle_identifier" \
        "$team_identifier" || return 1
    if [[ "$update_feed_url" != https://* \
          || "$update_feed_url" == *".invalid"* ]]; then
        release_error "UpdateFeedURL must be a reviewed HTTPS production URL."
        return 1
    fi
    if [[ "$update_download_url_prefix" != https://* \
          || "$update_download_url_prefix" == *".invalid"* \
          || "$update_download_url_prefix" != */ ]]; then
        release_error "UpdateDownloadURLPrefix must be a reviewed HTTPS directory URL ending in /."
        return 1
    fi
    if [[ "$update_feed_url" \
          != "${update_download_url_prefix}appcast.xml" ]]; then
        release_error "UpdateFeedURL must publish appcast.xml beside update archives."
        return 1
    fi
    if [[ "$product_url" != https://* \
          || "$product_url" == *".invalid"* ]]; then
        release_error "ProductURL must be a reviewed HTTPS production URL."
        return 1
    fi
    decoded_key="$(mktemp "${TMPDIR:-/tmp}/speaker-update-key.XXXXXX")" || {
        release_error "Unable to create update-key verification file."
        return 1
    }
    if ! print -rn -- "$update_public_ed_key" \
        | /usr/bin/base64 -D > "$decoded_key" 2>/dev/null; then
        rm -f "$decoded_key"
        release_error "UpdatePublicEDKey is not valid base64."
        return 1
    fi
    decoded_key_size="$(wc -c < "$decoded_key" | tr -d '[:space:]')"
    rm -f "$decoded_key"
    if [[ "$decoded_key_size" != "32" ]]; then
        release_error "UpdatePublicEDKey must decode to 32 bytes."
        return 1
    fi

    typeset -g REVIEWED_RELEASE_BUNDLE_IDENTIFIER="$bundle_identifier"
    typeset -g REVIEWED_RELEASE_TEAM_IDENTIFIER="$team_identifier"
    typeset -g REVIEWED_UPDATE_FEED_URL="$update_feed_url"
    typeset -g REVIEWED_UPDATE_DOWNLOAD_URL_PREFIX="$update_download_url_prefix"
    typeset -g REVIEWED_PRODUCT_URL="$product_url"
    typeset -g REVIEWED_UPDATE_PUBLIC_ED_KEY="$update_public_ed_key"
}

load_reviewed_release_candidate() {
    local root="$1"
    local candidate_file="$root/Resources/ReleaseCandidate.plist"
    local previous_build
    local version
    local build_number

    if [[ ! -f "$candidate_file" || -L "$candidate_file" ]]; then
        release_error "Reviewed release candidate is missing or unsafe: $candidate_file"
        return 1
    fi
    if ! plutil -lint "$candidate_file" >/dev/null; then
        release_error "ReleaseCandidate.plist is not a valid property list."
        return 1
    fi
    previous_build="$(
        /usr/libexec/PlistBuddy \
            -c 'Print :PreviousPublishedBuildNumber' \
            "$candidate_file" 2>/dev/null
    )" || {
        release_error "ReleaseCandidate.plist is missing PreviousPublishedBuildNumber."
        return 1
    }
    version="$(
        /usr/libexec/PlistBuddy \
            -c 'Print :Version' \
            "$candidate_file" 2>/dev/null
    )" || {
        release_error "ReleaseCandidate.plist is missing Version."
        return 1
    }
    build_number="$(
        /usr/libexec/PlistBuddy \
            -c 'Print :BuildNumber' \
            "$candidate_file" 2>/dev/null
    )" || {
        release_error "ReleaseCandidate.plist is missing BuildNumber."
        return 1
    }
    if [[ "$version" == REPLACE_* || "$build_number" == REPLACE_* ]]; then
        release_error "Formal release candidate has not been reviewed."
        return 1
    fi
    validate_production_metadata \
        "$version" \
        "$build_number" \
        "$REVIEWED_RELEASE_BUNDLE_IDENTIFIER" \
        "$REVIEWED_RELEASE_TEAM_IDENTIFIER" || return 1
    if ! matches_release_pattern "$previous_build" '^(0|[1-9][0-9]*)$'; then
        release_error "PreviousPublishedBuildNumber must be a non-negative integer."
        return 1
    fi
    if [[ "$previous_build" != "0" ]] \
          && ! release_build_is_greater "$build_number" "$previous_build"; then
        release_error "Reviewed build $build_number must be newer than published build $previous_build."
        return 1
    fi

    typeset -g REVIEWED_PREVIOUS_PUBLISHED_BUILD_NUMBER="$previous_build"
    typeset -g REVIEWED_RELEASE_VERSION="$version"
    typeset -g REVIEWED_RELEASE_BUILD_NUMBER="$build_number"
}

reject_release_candidate_override() {
    local requested_version="$1"
    local requested_build="$2"

    if [[ "$requested_version" != "$REVIEWED_RELEASE_VERSION" \
          || "$requested_build" != "$REVIEWED_RELEASE_BUILD_NUMBER" ]]; then
        release_error "SPEAKER_VERSION and SPEAKER_BUILD_NUMBER must match the reviewed release candidate."
        return 1
    fi
}

verify_release_candidate_history() {
    local root="$1"
    local relative_path="Resources/ReleaseCandidate.plist"
    local -a revisions
    local prior_file
    local prior_published_build
    local current_published_build="$REVIEWED_PREVIOUS_PUBLISHED_BUILD_NUMBER"

    git -C "$root" ls-files --error-unmatch "$relative_path" >/dev/null || {
        release_error "ReleaseCandidate.plist must be tracked before a formal release."
        return 1
    }
    revisions=("${(@f)$(
        git -C "$root" log --format='%H' --max-count=2 -- "$relative_path"
    )}")
    (( ${#revisions} >= 2 )) || return 0
    prior_file="$(mktemp "${TMPDIR:-/tmp}/speaker-prior-candidate.XXXXXX")" \
        || return 1
    if ! git -C "$root" show "${revisions[2]}:$relative_path" > "$prior_file"; then
        rm -f "$prior_file"
        release_error "Unable to inspect the previous reviewed release candidate."
        return 1
    fi
    prior_published_build="$(
        /usr/libexec/PlistBuddy \
            -c 'Print :PreviousPublishedBuildNumber' \
            "$prior_file" 2>/dev/null
    )" || {
        rm -f "$prior_file"
        release_error "Previous ReleaseCandidate.plist has no published-build ledger."
        return 1
    }
    rm -f "$prior_file"
    matches_release_pattern "$prior_published_build" '^(0|[1-9][0-9]*)$' || return 1
    if [[ "$current_published_build" == "$prior_published_build" ]]; then
        return 0
    fi
    if [[ "$current_published_build" == "0" ]]; then
        release_error "PreviousPublishedBuildNumber cannot move backwards."
        return 1
    fi
    if [[ "$prior_published_build" != "0" ]] \
          && ! release_build_is_greater \
              "$current_published_build" \
              "$prior_published_build"; then
        release_error "PreviousPublishedBuildNumber cannot move backwards."
        return 1
    fi
}

resolve_sparkle_release_tools() {
    local root="$1"
    local artifacts_root="${SPEAKER_SWIFT_SCRATCH_PATH:-$root/.build}"
    local tools_root="$artifacts_root/artifacts/sparkle/Sparkle/bin"
    local tool
    local architectures
    local component=""

    for component in ${(s:/:)tools_root}; do
        [[ -z "$component" ]] && continue
        tool="${tool:-}/$component"
        if [[ -L "$tool" ]]; then
            release_error "Sparkle tool path contains a symbolic link: $tool"
            return 1
        fi
    done
    for tool in \
        "$tools_root/generate_appcast" \
        "$tools_root/generate_keys" \
        "$tools_root/sign_update"; do
        if [[ ! -f "$tool" || -L "$tool" || ! -x "$tool" ]]; then
            release_error "Required canonical Sparkle tool is unavailable: $tool"
            return 1
        fi
        codesign --verify --strict "$tool" || {
            release_error "Sparkle publishing tool failed code-integrity verification: $tool"
            return 1
        }
        architectures="$(lipo -archs "$tool")" || return 1
        if [[ "$architectures" != "arm64 x86_64" \
              && "$architectures" != "x86_64 arm64" ]]; then
            release_error "Sparkle publishing tool is not the reviewed universal artifact: $tool"
            return 1
        fi
    done

    typeset -g REVIEWED_SPARKLE_TOOLS_ROOT="$tools_root"
    typeset -g REVIEWED_SPARKLE_GENERATE_APPCAST="$tools_root/generate_appcast"
    typeset -g REVIEWED_SPARKLE_GENERATE_KEYS="$tools_root/generate_keys"
    typeset -g REVIEWED_SPARKLE_SIGN_UPDATE="$tools_root/sign_update"
}

rollback_release_promotion() {
    local archive="$1"
    local checksum="$2"
    local appcast="$3"
    local pending_appcast="$4"
    local previous_appcast="$5"
    local had_previous_appcast="$6"
    local recovery_appcast="${appcast}.recovery.$$"

    rm -f "$pending_appcast"
    if [[ "$had_previous_appcast" == "1" ]]; then
        [[ -f "$previous_appcast" && ! -L "$previous_appcast" ]] || {
            release_error "Cannot restore the previous appcast during release rollback."
            return 1
        }
        cp "$previous_appcast" "$recovery_appcast"
        mv -f "$recovery_appcast" "$appcast"
    else
        rm -f "$appcast"
    fi
    rm -f "$archive" "$checksum"
}

release_journal_value() {
    local journal="$1"
    local name="$2"
    local pattern="$3"
    local file="$journal/$name"
    local size
    local value

    if [[ ! -f "$file" || -L "$file" ]]; then
        release_error "Release promotion journal is missing a safe $name field."
        return 1
    fi
    size="$(stat -f %z "$file")" || return 1
    if ! matches_release_pattern "$size" '^[0-9]+$' || (( size > 512 )); then
        release_error "Release promotion journal field is too large: $name"
        return 1
    fi
    value="$(<"$file")"
    if ! matches_release_pattern "$value" "$pattern"; then
        release_error "Release promotion journal contains an invalid $name field."
        return 1
    fi
    print -r -- "$value"
}

verify_journal_owned_file() {
    local file_path="$1"
    local expected_hash="$2"
    local label="$3"
    local required="$4"
    local actual_hash

    if [[ ! -e "$file_path" && ! -L "$file_path" ]]; then
        [[ "$required" == "0" ]] && return 0
        release_error "Committed release is missing $label."
        return 1
    fi
    if [[ ! -f "$file_path" || -L "$file_path" ]]; then
        release_error "Release $label path is unsafe."
        return 1
    fi
    actual_hash="$(shasum -a 256 "$file_path" | awk '{print $1}')" \
        || return 1
    if [[ "$actual_hash" != "$expected_hash" ]]; then
        release_error "Release $label is not owned by this journal."
        return 1
    fi
}

prepare_release_promotion_journal() {
    local output_dir="$1"
    local archive_basename="$2"
    local checksum_basename="$3"
    local previous_appcast="$4"
    local had_previous_appcast="$5"
    local pending_archive="$6"
    local pending_checksum="$7"
    local pending_appcast="$8"
    local evidence_basename="$9"
    local evidence_checksum_basename="${10}"
    local pending_evidence="${11}"
    local pending_evidence_checksum="${12}"
    local journal="$output_dir/.promotion-journal"
    local staging="$output_dir/.promotion-journal.pending"
    local archive_hash
    local checksum_hash
    local appcast_hash
    local previous_appcast_hash=""
    local evidence_hash
    local evidence_checksum_hash

    if [[ ! -d "$output_dir" || -L "$output_dir" ]]; then
        release_error "Release output directory is not a safe directory."
        return 1
    fi
    if ! matches_release_pattern \
        "$archive_basename" \
        '^Speaker-[0-9A-Za-z.+-]+-[1-9][0-9]*\.dmg$' \
        || [[ "$checksum_basename" != "$archive_basename.sha256" ]] \
        || ! matches_release_pattern \
            "$evidence_basename" \
            '^Speaker-[0-9A-Za-z.+-]+-[1-9][0-9]*-evidence\.zip$' \
        || [[ "$evidence_checksum_basename" \
              != "$evidence_basename.sha256" ]] \
        || [[ "$evidence_basename" \
              != "${archive_basename%.dmg}-evidence.zip" ]] \
        || [[ "$had_previous_appcast" != "0" \
              && "$had_previous_appcast" != "1" ]]; then
        release_error "Refusing invalid release promotion journal metadata."
        return 1
    fi
    if [[ -e "$journal" || -L "$journal" \
          || -e "$staging" || -L "$staging" ]]; then
        release_error "A release promotion journal already exists."
        return 1
    fi
    for release_file in \
        "$pending_archive" \
        "$pending_checksum" \
        "$pending_appcast" \
        "$pending_evidence" \
        "$pending_evidence_checksum"; do
        if [[ ! -f "$release_file" || -L "$release_file" ]]; then
            release_error "Cannot journal an unsafe pending release file."
            return 1
        fi
    done
    archive_hash="$(shasum -a 256 "$pending_archive" | awk '{print $1}')" \
        || return 1
    checksum_hash="$(shasum -a 256 "$pending_checksum" | awk '{print $1}')" \
        || return 1
    appcast_hash="$(shasum -a 256 "$pending_appcast" | awk '{print $1}')" \
        || return 1
    evidence_hash="$(shasum -a 256 "$pending_evidence" | awk '{print $1}')" \
        || return 1
    evidence_checksum_hash="$(
        shasum -a 256 "$pending_evidence_checksum" | awk '{print $1}'
    )" || return 1
    mkdir "$staging"
    chmod 700 "$staging"
    print -r -- prepared > "$staging/state"
    print -r -- "$archive_basename" > "$staging/archive-name"
    print -r -- "$checksum_basename" > "$staging/checksum-name"
    print -r -- "$had_previous_appcast" > "$staging/had-previous-appcast"
    print -r -- "$archive_hash" > "$staging/archive-sha256"
    print -r -- "$checksum_hash" > "$staging/checksum-sha256"
    print -r -- "$appcast_hash" > "$staging/appcast-sha256"
    print -r -- "$evidence_basename" > "$staging/evidence-name"
    print -r -- "$evidence_checksum_basename" \
        > "$staging/evidence-checksum-name"
    print -r -- "$evidence_hash" > "$staging/evidence-sha256"
    print -r -- "$evidence_checksum_hash" \
        > "$staging/evidence-checksum-sha256"
    chmod 600 "$staging"/*
    if [[ "$had_previous_appcast" == "1" ]]; then
        if [[ ! -f "$previous_appcast" || -L "$previous_appcast" ]]; then
            rm -rf "$staging"
            release_error "Cannot journal the previous release appcast."
            return 1
        fi
        cp "$previous_appcast" "$staging/previous-appcast.xml"
        chmod 600 "$staging/previous-appcast.xml"
        previous_appcast_hash="$(
            shasum -a 256 "$staging/previous-appcast.xml" | awk '{print $1}'
        )" || {
            rm -rf "$staging"
            return 1
        }
        print -r -- "$previous_appcast_hash" \
            > "$staging/previous-appcast-sha256"
        chmod 600 "$staging/previous-appcast-sha256"
    fi
    /bin/sync
    mv "$staging" "$journal"
    /bin/sync
}

mark_release_promotion_committed() {
    local output_dir="$1"
    local journal="$output_dir/.promotion-journal"
    local state

    if [[ ! -d "$journal" || -L "$journal" ]]; then
        release_error "Cannot commit a missing release promotion journal."
        return 1
    fi
    state="$(release_journal_value "$journal" state '^(prepared|committed)$')" \
        || return 1
    [[ "$state" == prepared ]] || {
        release_error "Release promotion journal is not prepared."
        return 1
    }
    print -r -- committed > "$journal/state.pending"
    chmod 600 "$journal/state.pending"
    /bin/sync
    mv -f "$journal/state.pending" "$journal/state"
    /bin/sync
}

recover_interrupted_release_promotion() {
    local output_dir="$1"
    local journal="$output_dir/.promotion-journal"
    local staging="$output_dir/.promotion-journal.pending"
    local appcast="$output_dir/appcast.xml"
    local appcast_pending="$output_dir/.appcast.xml.pending"
    local recovery_appcast="$output_dir/.appcast.xml.recovery.$$"
    local state
    local archive_basename
    local checksum_basename
    local had_previous_appcast
    local archive
    local checksum
    local checksum_line
    local expected_hash
    local actual_hash
    local archive_hash
    local checksum_hash
    local appcast_hash
    local previous_appcast_hash=""
    local existing_hash
    local checksum_size
    local evidence_basename
    local evidence_checksum_basename
    local evidence
    local evidence_checksum
    local evidence_hash
    local evidence_checksum_hash
    local evidence_checksum_line
    local evidence_checksum_size

    if [[ -L "$output_dir" || ! -d "$output_dir" ]]; then
        release_error "Release output directory is not a safe directory."
        return 1
    fi
    if [[ -e "$staging" || -L "$staging" ]]; then
        if [[ -L "$staging" || ! -d "$staging" ]]; then
            release_error "Unsafe incomplete release journal staging path."
            return 1
        fi
        rm -rf "$staging"
    fi
    [[ -e "$journal" || -L "$journal" ]] || return 0
    if [[ -L "$journal" || ! -d "$journal" ]]; then
        release_error "Unsafe release promotion journal."
        return 1
    fi
    state="$(release_journal_value "$journal" state '^(prepared|committed)$')" \
        || return 1
    archive_basename="$(
        release_journal_value \
            "$journal" \
            archive-name \
            '^Speaker-[0-9A-Za-z.+-]+-[1-9][0-9]*\.dmg$'
    )" || return 1
    checksum_basename="$(
        release_journal_value \
            "$journal" \
            checksum-name \
            '^Speaker-[0-9A-Za-z.+-]+-[1-9][0-9]*\.dmg\.sha256$'
    )" || return 1
    had_previous_appcast="$(
        release_journal_value \
            "$journal" \
            had-previous-appcast \
            '^[01]$'
    )" || return 1
    archive_hash="$(
        release_journal_value "$journal" archive-sha256 '^[0-9a-f]{64}$'
    )" || return 1
    checksum_hash="$(
        release_journal_value "$journal" checksum-sha256 '^[0-9a-f]{64}$'
    )" || return 1
    appcast_hash="$(
        release_journal_value "$journal" appcast-sha256 '^[0-9a-f]{64}$'
    )" || return 1
    evidence_basename="$(
        release_journal_value \
            "$journal" \
            evidence-name \
            '^Speaker-[0-9A-Za-z.+-]+-[1-9][0-9]*-evidence\.zip$'
    )" || return 1
    evidence_checksum_basename="$(
        release_journal_value \
            "$journal" \
            evidence-checksum-name \
            '^Speaker-[0-9A-Za-z.+-]+-[1-9][0-9]*-evidence\.zip\.sha256$'
    )" || return 1
    evidence_hash="$(
        release_journal_value "$journal" evidence-sha256 '^[0-9a-f]{64}$'
    )" || return 1
    evidence_checksum_hash="$(
        release_journal_value \
            "$journal" \
            evidence-checksum-sha256 \
            '^[0-9a-f]{64}$'
    )" || return 1
    [[ "$checksum_basename" == "$archive_basename.sha256" ]] || {
        release_error "Release promotion journal artifact names do not match."
        return 1
    }
    [[ "$evidence_checksum_basename" == "$evidence_basename.sha256" ]] || {
        release_error "Release evidence journal artifact names do not match."
        return 1
    }
    [[ "$evidence_basename" \
        == "${archive_basename%.dmg}-evidence.zip" ]] || {
        release_error "Release evidence does not belong to the journaled DMG."
        return 1
    }
    archive="$output_dir/$archive_basename"
    checksum="$output_dir/$checksum_basename"
    evidence="$output_dir/$evidence_basename"
    evidence_checksum="$output_dir/$evidence_checksum_basename"

    if [[ "$had_previous_appcast" == "1" ]]; then
        previous_appcast_hash="$(
            release_journal_value \
                "$journal" \
                previous-appcast-sha256 \
                '^[0-9a-f]{64}$'
        )" || return 1
        if [[ ! -f "$journal/previous-appcast.xml" \
              || -L "$journal/previous-appcast.xml" ]]; then
            release_error "Cannot verify the previous appcast from the release journal."
            return 1
        fi
        existing_hash="$(
            shasum -a 256 "$journal/previous-appcast.xml" | awk '{print $1}'
        )" || return 1
        if [[ "$existing_hash" != "$previous_appcast_hash" ]]; then
            release_error "Previous appcast does not match the release journal."
            return 1
        fi
        xmllint --noout "$journal/previous-appcast.xml" || return 1
    fi

    if [[ "$state" == committed ]]; then
        if [[ ! -f "$appcast" || -L "$appcast" ]]; then
            release_error "Committed release promotion is incomplete; preserving its journal for inspection."
            return 1
        fi
        verify_journal_owned_file "$archive" "$archive_hash" archive 1 || return 1
        verify_journal_owned_file "$checksum" "$checksum_hash" checksum 1 || return 1
        verify_journal_owned_file "$evidence" "$evidence_hash" evidence 1 || return 1
        verify_journal_owned_file \
            "$evidence_checksum" \
            "$evidence_checksum_hash" \
            evidence-checksum \
            1 || return 1
        existing_hash="$(shasum -a 256 "$appcast" | awk '{print $1}')" \
            || return 1
        [[ "$existing_hash" == "$appcast_hash" ]] || {
            release_error "Committed appcast is not owned by its journal."
            return 1
        }
        checksum_size="$(stat -f %z "$checksum")" || return 1
        if (( checksum_size > 512 )); then
            release_error "Committed release checksum is unexpectedly large."
            return 1
        fi
        checksum_line="$(<"$checksum")"
        validate_portable_checksum_line \
            "$checksum_line" \
            "$archive_basename" || return 1
        expected_hash="${checksum_line%%  *}"
        actual_hash="$(shasum -a 256 "$archive" | awk '{print $1}')" || return 1
        if [[ "$actual_hash" != "$expected_hash" ]]; then
            release_error "Committed release archive does not match its checksum."
            return 1
        fi
        evidence_checksum_size="$(stat -f %z "$evidence_checksum")" \
            || return 1
        if (( evidence_checksum_size > 512 )); then
            release_error "Committed evidence checksum is unexpectedly large."
            return 1
        fi
        evidence_checksum_line="$(<"$evidence_checksum")"
        validate_portable_checksum_line \
            "$evidence_checksum_line" \
            "$evidence_basename" || return 1
        expected_hash="${evidence_checksum_line%%  *}"
        actual_hash="$(shasum -a 256 "$evidence" | awk '{print $1}')" \
            || return 1
        [[ "$actual_hash" == "$expected_hash" ]] || {
            release_error "Committed evidence archive does not match its checksum."
            return 1
        }
        xmllint --noout "$appcast" || return 1
        rm -f "$appcast_pending"
        rm -rf "$journal"
        /bin/sync
        return 0
    fi

    verify_journal_owned_file "$archive" "$archive_hash" archive 0 || return 1
    verify_journal_owned_file "$checksum" "$checksum_hash" checksum 0 || return 1
    verify_journal_owned_file "$evidence" "$evidence_hash" evidence 0 || return 1
    verify_journal_owned_file \
        "$evidence_checksum" \
        "$evidence_checksum_hash" \
        evidence-checksum \
        0 || return 1
    if [[ -e "$appcast_pending" || -L "$appcast_pending" ]]; then
        if [[ ! -f "$appcast_pending" || -L "$appcast_pending" ]]; then
            release_error "Prepared pending appcast path is unsafe."
            return 1
        fi
        existing_hash="$(
            shasum -a 256 "$appcast_pending" | awk '{print $1}'
        )" || return 1
        [[ "$existing_hash" == "$appcast_hash" ]] || {
            release_error "Refusing to delete an appcast not owned by this release journal."
            return 1
        }
    fi
    if [[ -e "$appcast" || -L "$appcast" ]]; then
        if [[ ! -f "$appcast" || -L "$appcast" ]]; then
            release_error "Prepared release appcast path is unsafe."
            return 1
        fi
        existing_hash="$(shasum -a 256 "$appcast" | awk '{print $1}')" \
            || return 1
        if [[ "$existing_hash" != "$appcast_hash" \
              && ( "$had_previous_appcast" != "1" \
                   || "$existing_hash" != "$previous_appcast_hash" ) ]]; then
            release_error "Refusing to replace an appcast not owned by this release journal."
            return 1
        fi
    fi

    rm -f "$appcast_pending"
    if [[ "$had_previous_appcast" == "1" ]]; then
        cp "$journal/previous-appcast.xml" "$recovery_appcast"
        mv -f "$recovery_appcast" "$appcast"
    else
        rm -f "$appcast"
    fi
    rm -f "$archive" "$checksum" "$evidence" "$evidence_checksum"
    /bin/sync
    rm -rf "$journal"
    /bin/sync
}

recover_stale_release_pending_directories() {
    local output_dir="$1"
    local pending
    local marker
    local mount_point
    local marker_value
    local -a contents
    local -a pending_directories

    if [[ ! -d "$output_dir" || -L "$output_dir" ]]; then
        release_error "Release output directory is not a safe directory."
        return 1
    fi
    pending_directories=("$output_dir"/.pending.*(N/))
    for pending in "${pending_directories[@]}"; do
        if [[ -L "$pending" \
              || "$(stat -f %u "$pending")" != "$UID" \
              || "$(stat -f %Lp "$pending")" != "700" ]]; then
            release_error "Refusing an unsafe stale release pending directory: $pending"
            return 1
        fi
        marker="$pending/.speaker-release-pending"
        contents=("$pending"/*(ND))
        if (( ${#contents} == 0 )); then
            rmdir "$pending"
            continue
        fi
        if [[ ! -f "$marker" || -L "$marker" ]]; then
            release_error "Unrecognized stale release pending directory; preserving it: $pending"
            return 1
        fi
        marker_value="$(<"$marker")"
        if [[ "$marker_value" != speaker-release-pending-v1 ]]; then
            release_error "Invalid stale release pending marker; preserving it: $pending"
            return 1
        fi
        mount_point="$pending/mount"
        if mount | grep -Fq -- " on $mount_point ("; then
            hdiutil detach "$mount_point" >/dev/null
        fi
        if mount | grep -Fq -- " on $mount_point ("; then
            release_error "Unable to detach stale release image: $mount_point"
            return 1
        fi
        chmod -R -P u+w "$pending" 2>/dev/null || true
        rm -rf "$pending"
    done
}

reject_release_identity_override() {
    local requested_bundle_identifier="$1"
    local requested_team_identifier="$2"

    if [[ -n "$requested_bundle_identifier" \
          && "$requested_bundle_identifier" \
            != "$REVIEWED_RELEASE_BUNDLE_IDENTIFIER" ]]; then
        release_error "SPEAKER_BUNDLE_IDENTIFIER cannot override the reviewed release identity."
        return 1
    fi
    if [[ -n "$requested_team_identifier" \
          && "$requested_team_identifier" \
            != "$REVIEWED_RELEASE_TEAM_IDENTIFIER" ]]; then
        release_error "SPEAKER_EXPECTED_TEAM_ID cannot override the reviewed release identity."
        return 1
    fi
}

verify_sparkle_layout() {
    local app="$1"
    local executable="$app/Contents/MacOS/SpeakerApp"
    local framework="$app/Contents/Frameworks/Sparkle.framework"
    local updater="$framework/Versions/Current/Updater.app"
    local autoupdate="$framework/Versions/Current/Autoupdate"
    local dependency
    local rpaths

    [[ -x "$executable" ]] || {
        release_error "Speaker executable is missing from the app bundle."
        return 1
    }
    [[ -d "$framework" && -d "$updater" && -x "$autoupdate" ]] || {
        release_error "The embedded Sparkle framework is incomplete."
        return 1
    }
    if [[ -e "$framework/XPCServices" || -L "$framework/XPCServices" \
          || -e "$framework/Versions/Current/XPCServices" ]]; then
        release_error "A non-sandboxed Speaker build must not embed Sparkle XPC services."
        return 1
    fi

    dependency="$(
        otool -L "$executable" \
            | sed -nE 's/^[[:space:]]+(@rpath\/Sparkle\.framework\/Versions\/B\/Sparkle) .*/\1/p'
    )"
    if [[ "$dependency" != "@rpath/Sparkle.framework/Versions/B/Sparkle" ]]; then
        release_error "Speaker does not load the reviewed Sparkle framework path."
        return 1
    fi
    rpaths="$(
        otool -l "$executable" \
            | awk '
                $1 == "cmd" && $2 == "LC_RPATH" {
                    getline
                    getline
                    sub(/^[[:space:]]*path[[:space:]]+/, "")
                    sub(/[[:space:]]+\(offset.*$/, "")
                    print
                }
            '
    )"
    if ! grep -Fqx -- '@executable_path/../Frameworks' <<< "$rpaths"; then
        release_error "Speaker is missing its private Frameworks runtime search path."
        return 1
    fi

    codesign --verify --strict --verbose=2 "$framework" || {
        release_error "Sparkle framework signature verification failed."
        return 1
    }
    codesign --verify --strict --verbose=2 "$updater" || {
        release_error "Sparkle Updater signature verification failed."
        return 1
    }
    codesign --verify --strict --verbose=2 "$autoupdate" || {
        release_error "Sparkle Autoupdate signature verification failed."
        return 1
    }
}

verify_production_sparkle_signatures() {
    local app="$1"
    local expected_team_id="$2"
    local framework="$app/Contents/Frameworks/Sparkle.framework"
    local component
    local signature_info
    local -a components

    components=(
        "$framework"
        "$framework/Versions/Current/Updater.app"
        "$framework/Versions/Current/Autoupdate"
    )
    for component in "${components[@]}"; do
        if ! signature_info="$(codesign -d --verbose=4 "$component" 2>&1)"; then
            release_error "Unable to inspect embedded Sparkle signature: $component"
            return 1
        fi
        if ! grep -Fqx -- "TeamIdentifier=$expected_team_id" <<< "$signature_info"; then
            release_error "Embedded Sparkle code has an unexpected Team ID: $component"
            return 1
        fi
        if ! grep -Eq -- '^Authority=Developer ID Application:' <<< "$signature_info"; then
            release_error "Embedded Sparkle code is not Developer ID signed: $component"
            return 1
        fi
        if ! grep -Eq -- '^CodeDirectory .*flags=.*runtime' <<< "$signature_info"; then
            release_error "Embedded Sparkle code lacks Hardened Runtime: $component"
            return 1
        fi
        if ! grep -Eq -- '^Timestamp=' <<< "$signature_info"; then
            release_error "Embedded Sparkle code lacks a trusted timestamp: $component"
            return 1
        fi
    done
}

verify_production_app() {
    local app="$1"
    local expected_bundle_identifier="$2"
    local expected_team_id="$3"
    local expected_entitlements="$4"
    local expected_update_feed_url="$5"
    local expected_update_public_key="$6"
    local signature_info
    local actual_entitlements
    local actual_json
    local expected_json
    local architectures
    local rpath
    local -a rpaths

    if ! codesign --verify --deep --strict --verbose=2 "$app"; then
        release_error "Production signature verification failed: $app"
        return 1
    fi
    architectures="$(lipo -archs "$app/Contents/MacOS/SpeakerApp")" || {
        release_error "Unable to inspect production executable architectures."
        return 1
    }
    if [[ "$architectures" != "arm64 x86_64" \
          && "$architectures" != "x86_64 arm64" ]]; then
        release_error "Production executable must contain exactly arm64 and x86_64."
        return 1
    fi

    if ! signature_info="$(codesign -d --verbose=4 "$app" 2>&1)"; then
        release_error "Unable to inspect production signature: $app"
        return 1
    fi
    if ! grep -Fqx -- "Identifier=$expected_bundle_identifier" <<< "$signature_info"; then
        release_error "Signed identifier does not match $expected_bundle_identifier."
        return 1
    fi
    if ! grep -Fqx -- "TeamIdentifier=$expected_team_id" <<< "$signature_info"; then
        release_error "Signed Team ID does not match $expected_team_id."
        return 1
    fi
    if ! grep -Eq -- '^Authority=Developer ID Application:' <<< "$signature_info"; then
        release_error "Signature is not a Developer ID Application signature."
        return 1
    fi
    if ! grep -Eq -- '^CodeDirectory .*flags=.*runtime' <<< "$signature_info"; then
        release_error "Hardened Runtime is not enabled."
        return 1
    fi
    if ! grep -Eq -- '^Timestamp=' <<< "$signature_info"; then
        release_error "Production signature is missing a trusted timestamp."
        return 1
    fi
    rpaths=("${(@f)$(
        otool -l "$app/Contents/MacOS/SpeakerApp" \
            | awk '/cmd LC_RPATH/{getline; getline; print $2}'
    )}")
    typeset -U rpaths
    for rpath in "${rpaths[@]}"; do
        case "$rpath" in
            /usr/lib/swift|@loader_path|@executable_path/../Frameworks)
                ;;
            *)
                release_error "Production executable contains an unreviewed RPATH: $rpath"
                return 1
                ;;
        esac
    done

    if ! actual_entitlements="$(mktemp "${TMPDIR:-/tmp}/speaker-entitlements.XXXXXX")"; then
        release_error "Unable to create an entitlement verification file."
        return 1
    fi
    if ! codesign -d --entitlements :- "$app" > "$actual_entitlements" 2>/dev/null; then
        rm -f "$actual_entitlements"
        release_error "Unable to read signed entitlements."
        return 1
    fi
    if ! actual_json="$(plutil -convert json -o - "$actual_entitlements" 2>/dev/null)"; then
        rm -f "$actual_entitlements"
        release_error "Signed entitlements are not a valid property list."
        return 1
    fi
    rm -f "$actual_entitlements"
    if ! expected_json="$(plutil -convert json -o - "$expected_entitlements" 2>/dev/null)"; then
        release_error "Expected entitlements are not a valid property list."
        return 1
    fi
    if [[ "$actual_json" != "$expected_json" ]]; then
        release_error "Signed entitlements differ from the reviewed production entitlements."
        return 1
    fi

    verify_production_update_configuration \
        "$app" \
        "$expected_bundle_identifier" \
        "$expected_update_feed_url" \
        "$expected_update_public_key"
}

verify_production_update_configuration() {
    local app="$1"
    local expected_bundle_identifier="$2"
    local expected_feed_url="$3"
    local expected_public_key="$4"
    local info="$app/Contents/Info.plist"
    local key
    local expected
    local actual

    local -a exact_values=(
        "SpeakerSigningMode|developer-id"
        "SpeakerCredentialStorage|keychain"
        "SpeakerKeychainService|$expected_bundle_identifier.provider-api-keys"
        "SUFeedURL|$expected_feed_url"
        "SUPublicEDKey|$expected_public_key"
        "SUVerifyUpdateBeforeExtraction|true"
        "SURequireSignedFeed|true"
        "SUSignedFeedFailureExpirationInterval|0"
        "SUEnableAutomaticChecks|false"
        "SUAutomaticallyUpdate|false"
        "SUEnableSystemProfiling|false"
        "SUEnableJavaScript|false"
    )
    for entry in "${exact_values[@]}"; do
        key="${entry%%|*}"
        expected="${entry#*|}"
        actual="$(/usr/libexec/PlistBuddy -c "Print :$key" "$info" 2>/dev/null)" || {
            release_error "Production app is missing reviewed update policy: $key"
            return 1
        }
        if [[ "$actual" != "$expected" ]]; then
            release_error "Production app has unexpected update policy for $key."
            return 1
        fi
    done
}

verify_production_build_provenance() {
    local app="$1"
    local expected_source_commit="$2"
    local expected_package_hash="$3"
    local expected_release_notes_hash="$4"
    local expected_version="$5"
    local expected_build_number="$6"
    local manifest="$app/Contents/Resources/BuildManifest.plist"
    local key
    local expected
    local actual

    if [[ ! -f "$manifest" || -L "$manifest" ]] \
          || ! plutil -lint "$manifest" >/dev/null; then
        release_error "Production app is missing a valid signed build manifest."
        return 1
    fi
    local -a exact_values=(
        "SchemaVersion|1"
        "SourceCommit|$expected_source_commit"
        "PackageResolvedSHA256|$expected_package_hash"
        "ReleaseNotesSHA256|$expected_release_notes_hash"
        "Version|$expected_version"
        "BuildNumber|$expected_build_number"
    )
    for entry in "${exact_values[@]}"; do
        key="${entry%%|*}"
        expected="${entry#*|}"
        actual="$(
            /usr/libexec/PlistBuddy -c "Print :$key" "$manifest" 2>/dev/null
        )" || {
            release_error "Production build manifest is missing $key."
            return 1
        }
        if [[ "$actual" != "$expected" ]]; then
            release_error "Production build manifest does not match $key."
            return 1
        fi
    done
}

verify_production_build_provenance_shape() {
    local app="$1"
    local expected_version="$2"
    local expected_build_number="$3"
    local manifest="$app/Contents/Resources/BuildManifest.plist"
    local source_commit
    local package_hash
    local release_notes_hash

    source_commit="$(
        /usr/libexec/PlistBuddy -c 'Print :SourceCommit' "$manifest" 2>/dev/null
    )" || return 1
    package_hash="$(
        /usr/libexec/PlistBuddy -c 'Print :PackageResolvedSHA256' "$manifest" 2>/dev/null
    )" || return 1
    release_notes_hash="$(
        /usr/libexec/PlistBuddy -c 'Print :ReleaseNotesSHA256' "$manifest" 2>/dev/null
    )" || return 1
    if ! matches_release_pattern "$source_commit" '^[0-9a-f]{40}$' \
          || ! matches_release_pattern "$package_hash" '^[0-9a-f]{64}$' \
          || ! matches_release_pattern "$release_notes_hash" '^[0-9a-f]{64}$'; then
        release_error "Production build manifest contains invalid provenance hashes."
        return 1
    fi
    verify_production_build_provenance \
        "$app" \
        "$source_commit" \
        "$package_hash" \
        "$release_notes_hash" \
        "$expected_version" \
        "$expected_build_number"
}

verify_local_signed_app() {
    local app="$1"
    local expected_bundle_identifier="$2"
    local signature_info
    local designated_requirement

    if ! codesign --verify --deep --strict --verbose=2 "$app"; then
        release_error "Local signature verification failed: $app"
        return 1
    fi
    if ! signature_info="$(codesign -d --verbose=4 "$app" 2>&1)"; then
        release_error "Unable to inspect local signature: $app"
        return 1
    fi
    if ! grep -Fqx -- "Identifier=$expected_bundle_identifier" <<< "$signature_info"; then
        release_error "Signed identifier does not match $expected_bundle_identifier."
        return 1
    fi
    if grep -Fqx -- "Signature=adhoc" <<< "$signature_info"; then
        release_error "SPEAKER_LOCAL_CODESIGN_IDENTITY produced an ad-hoc signature."
        return 1
    fi
    if ! designated_requirement="$(codesign -d -r- "$app" 2>&1)"; then
        release_error "Unable to inspect the local designated requirement."
        return 1
    fi
    if grep -Eq -- 'designated => cdhash H"[0-9a-fA-F]+"' <<< "$designated_requirement"; then
        release_error "Local signature is still tied to a single build hash."
        return 1
    fi
}

signature_is_ad_hoc() {
    local app="$1"
    local signature_info

    signature_info="$(codesign -d --verbose=4 "$app" 2>&1)" || return 1
    grep -Fqx -- "Signature=adhoc" <<< "$signature_info"
}

designated_requirement() {
    local app="$1"
    local requirement

    requirement="$(codesign -d -r- "$app" 2>&1)" || return 1
    print -r -- "$requirement" \
        | sed -nE 's/^[[:space:]]*designated => /designated => /p'
}

verify_ad_hoc_app() {
    local app="$1"
    local expected_bundle_identifier="$2"
    local signature_info

    if ! codesign --verify --deep --strict --verbose=2 "$app"; then
        release_error "Ad-hoc signature verification failed: $app"
        return 1
    fi
    if ! signature_info="$(codesign -d --verbose=4 "$app" 2>&1)"; then
        release_error "Unable to inspect ad-hoc signature: $app"
        return 1
    fi
    if ! grep -Fqx -- "Identifier=$expected_bundle_identifier" <<< "$signature_info"; then
        release_error "Signed identifier does not match $expected_bundle_identifier."
        return 1
    fi
    if ! grep -Fqx -- "Signature=adhoc" <<< "$signature_info"; then
        release_error "Development bundle is not ad-hoc signed."
        return 1
    fi
}

verify_notarized_app() {
    local app="$1"
    local assessment

    if ! xcrun stapler validate "$app"; then
        release_error "The notarization ticket is missing or invalid."
        return 1
    fi
    if ! assessment="$(spctl --assess --type execute --verbose=4 "$app" 2>&1)"; then
        release_error "Gatekeeper rejected the app."
        return 1
    fi
    if ! grep -Fq -- 'source=Notarized Developer ID' <<< "$assessment"; then
        release_error "Gatekeeper did not identify the app as Notarized Developer ID."
        return 1
    fi
}

verify_notarized_dmg() {
    local dmg="$1"
    local assessment

    if ! xcrun stapler validate "$dmg"; then
        release_error "The DMG notarization ticket is missing or invalid."
        return 1
    fi
    if ! assessment="$(
        spctl \
            --assess \
            --type open \
            --context context:primary-signature \
            --verbose=4 \
            "$dmg" 2>&1
    )"; then
        release_error "Gatekeeper rejected the DMG."
        return 1
    fi
    if ! grep -Fq -- 'source=Notarized Developer ID' <<< "$assessment"; then
        release_error "Gatekeeper did not identify the DMG as Notarized Developer ID."
        return 1
    fi
}

validate_notary_submission_result() {
    local result_file="$1"
    local notary_status
    local submission_id

    if [[ ! -f "$result_file" || -L "$result_file" ]] \
          || ! plutil -convert xml1 -o /dev/null "$result_file" \
              >/dev/null 2>&1; then
        release_error "Notary submission result is not valid JSON or plist."
        return 1
    fi
    notary_status="$(plutil -extract status raw -o - "$result_file" 2>/dev/null)" \
        || {
            release_error "Notary submission result has no status."
            return 1
        }
    submission_id="$(plutil -extract id raw -o - "$result_file" 2>/dev/null)" \
        || {
            release_error "Notary submission result has no submission ID."
            return 1
        }
    if [[ "$notary_status" != Accepted ]] \
          || ! matches_release_pattern \
              "$submission_id" \
              '^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{12}$'; then
        release_error "Apple did not accept the notarization submission."
        return 1
    fi
    typeset -g REVIEWED_NOTARY_SUBMISSION_ID="$submission_id"
}

validate_notary_log() {
    local log_file="$1"
    local expected_submission_id="$2"
    local expected_sha256="$3"
    local expected_filename="$4"
    local actual_submission_id
    local notary_status
    local actual_sha256
    local actual_filename

    if [[ ! -f "$log_file" || -L "$log_file" ]] \
          || ! plutil -convert xml1 -o /dev/null "$log_file" \
              >/dev/null 2>&1; then
        release_error "Apple notarization log is not valid JSON."
        return 1
    fi
    actual_submission_id="$(
        plutil -extract jobId raw -o - "$log_file" 2>/dev/null
    )" || {
        release_error "Apple notarization log has no job ID."
        return 1
    }
    notary_status="$(plutil -extract status raw -o - "$log_file" 2>/dev/null)" \
        || {
            release_error "Apple notarization log has no status."
            return 1
        }
    actual_sha256="$(plutil -extract sha256 raw -o - "$log_file" 2>/dev/null)" \
        || {
            release_error "Apple notarization log has no archive hash."
            return 1
        }
    actual_filename="$(
        plutil -extract archiveFilename raw -o - "$log_file" 2>/dev/null
    )" || {
        release_error "Apple notarization log has no archive filename."
        return 1
    }
    if [[ "$actual_submission_id" != "$expected_submission_id" \
          || "$notary_status" != Accepted \
          || "$actual_sha256" != "$expected_sha256" \
          || "$actual_filename" != "$expected_filename" ]]; then
        release_error "Apple notarization log does not match the accepted submission."
        return 1
    fi
}

verify_dsym_matches_executable() {
    local executable="$1"
    local dsym="$2"
    local executable_uuids
    local dsym_uuids

    executable_uuids="$(
        dwarfdump --uuid "$executable" \
            | sed -E 's#^UUID: ([0-9A-F-]+) \(([^)]+)\).*$#\1 \2#' \
            | sort
    )" \
        || return 1
    dsym_uuids="$(
        dwarfdump --uuid "$dsym" \
            | sed -E 's#^UUID: ([0-9A-F-]+) \(([^)]+)\).*$#\1 \2#' \
            | sort
    )" \
        || return 1
    if [[ -z "$executable_uuids" || "$executable_uuids" != "$dsym_uuids" ]]; then
        release_error "dSYM UUIDs do not match the release executable."
        return 1
    fi
}

validate_release_evidence_archive() {
    local archive="$1"
    local expected_version="$2"
    local expected_build="$3"
    local expected_dmg_basename="$4"
    local expected_dmg_hash="$5"
    local expected_appcast_hash="$6"
    local expected_app_submission_hash="$7"
    local expected_dmg_submission_hash="$8"
    local expected_app_submission_id="$9"
    local expected_dmg_submission_id="${10}"
    local expected_executable="${11:-}"
    local listing
    local entry
    local required
    local count
    local entry_count
    local extracted
    local actual
    local key
    local sdk_canonical_name
    local sdk_settings_hash
    local recorded_sdk_canonical_name
    local recorded_sdk_settings_hash
    local recorded_sdk_path
    local -a required_entries=(
        ReleaseManifest.plist
        BuildManifest.plist
        Speaker.app.dSYM.zip
        app-notary-submission.json
        app-notary-log.json
        dmg-notary-submission.json
        dmg-notary-log.json
        swift-version.txt
        macos-version.txt
        sdk-path.txt
        sdk-version.txt
        sdk-settings-sha256.txt
        provider-matrix.json
    )

    if [[ ! -f "$archive" || -L "$archive" ]] \
          || ! unzip -tq "$archive" >/dev/null; then
        release_error "Release evidence archive is missing or invalid."
        return 1
    fi
    listing="$(unzip -Z1 "$archive")" || return 1
    for entry in "${(@f)listing}"; do
        if [[ "$entry" == /* || "$entry" == ../* \
              || "$entry" == */../* || "$entry" == */.. ]]; then
            release_error "Release evidence archive contains an unsafe path."
            return 1
        fi
    done
    entry_count="$(grep -c . <<< "$listing")"
    if [[ "$entry_count" != "${#required_entries}" ]]; then
        release_error "Release evidence archive contains unexpected entries."
        return 1
    fi
    for required in "${required_entries[@]}"; do
        count="$(grep -Fxc -- "$required" <<< "$listing" || true)"
        if [[ "$count" != "1" ]]; then
            release_error "Release evidence archive is missing $required."
            return 1
        fi
        if [[ "$(unzip -p "$archive" "$required" | wc -c | tr -d '[:space:]')" \
              == "0" ]]; then
            release_error "Release evidence entry is empty: $required"
            return 1
        fi
    done
    extracted="$(mktemp -d "${TMPDIR:-/tmp}/speaker-evidence-check.XXXXXX")" \
        || return 1
    chmod 700 "$extracted"
    for required in \
        ReleaseManifest.plist \
        BuildManifest.plist \
        Speaker.app.dSYM.zip \
        app-notary-submission.json \
        app-notary-log.json \
        dmg-notary-submission.json \
        dmg-notary-log.json \
        swift-version.txt \
        macos-version.txt \
        sdk-path.txt \
        sdk-version.txt \
        sdk-settings-sha256.txt \
        provider-matrix.json; do
        unzip -p "$archive" "$required" > "$extracted/$required" || {
            rm -rf "$extracted"
            return 1
        }
    done
    if ! plutil -lint "$extracted/ReleaseManifest.plist" >/dev/null \
          || ! plutil -lint "$extracted/BuildManifest.plist" >/dev/null \
          || ! unzip -tq "$extracted/Speaker.app.dSYM.zip" >/dev/null; then
        rm -rf "$extracted"
        release_error "Release evidence contains an invalid manifest or dSYM archive."
        return 1
    fi
    if [[ -n "$expected_executable" ]]; then
        local nested_listing
        nested_listing="$(unzip -Z1 "$extracted/Speaker.app.dSYM.zip")" \
            || {
                rm -rf "$extracted"
                return 1
            }
        for entry in "${(@f)nested_listing}"; do
            if [[ "$entry" == /* || "$entry" == ../* \
                  || "$entry" == */../* || "$entry" == */.. ]]; then
                rm -rf "$extracted"
                release_error "Nested dSYM archive contains an unsafe path."
                return 1
            fi
        done
        mkdir "$extracted/dsym"
        ditto -x -k \
            "$extracted/Speaker.app.dSYM.zip" \
            "$extracted/dsym" || {
            rm -rf "$extracted"
            return 1
        }
        local -a extracted_dsyms=("$extracted/dsym"/*.dSYM(N/))
        if (( ${#extracted_dsyms} != 1 )) \
              || ! verify_dsym_matches_executable \
                  "$expected_executable" \
                  "$extracted_dsyms[1]" \
              || ! dwarfdump --verify "$extracted_dsyms[1]" >/dev/null; then
            rm -rf "$extracted"
            release_error "Evidence dSYM does not match the release executable."
            return 1
        fi
    fi
    local -a manifest_values=(
        "SchemaVersion|2"
        "Version|$expected_version"
        "BuildNumber|$expected_build"
        "DMGBasename|$expected_dmg_basename"
        "DMGSHA256|$expected_dmg_hash"
        "AppcastSHA256|$expected_appcast_hash"
        "AppSubmissionSHA256|$expected_app_submission_hash"
        "DMGSubmissionSHA256|$expected_dmg_submission_hash"
        "AppNotarySubmissionID|$expected_app_submission_id"
        "DMGNotarySubmissionID|$expected_dmg_submission_id"
    )
    for entry in "${manifest_values[@]}"; do
        actual="$(
            /usr/libexec/PlistBuddy \
                -c "Print :${entry%%|*}" \
                "$extracted/ReleaseManifest.plist" 2>/dev/null
        )" || {
            rm -rf "$extracted"
            release_error "Release evidence manifest is incomplete."
            return 1
        }
        if [[ "$actual" != "${entry#*|}" ]]; then
            rm -rf "$extracted"
            release_error "Release evidence manifest does not match ${entry%%|*}."
            return 1
        fi
    done
    actual="$(shasum -a 256 "$extracted/provider-matrix.json" | awk '{print $1}')" \
        || {
            rm -rf "$extracted"
            return 1
        }
    if [[ "$actual" != "$(
        /usr/libexec/PlistBuddy \
            -c 'Print :ProviderEvidenceSHA256' \
            "$extracted/ReleaseManifest.plist" 2>/dev/null
    )" ]] || ! matches_release_pattern "$actual" '^[0-9a-f]{64}$'; then
        rm -rf "$extracted"
        release_error "Provider evidence hash does not match the release manifest."
        return 1
    fi
    for key in SourceCommit PackageResolvedSHA256 ReleaseNotesSHA256; do
        actual="$(
            /usr/libexec/PlistBuddy \
                -c "Print :$key" \
                "$extracted/ReleaseManifest.plist" 2>/dev/null
        )" || {
            rm -rf "$extracted"
            release_error "Release evidence manifest is missing $key."
            return 1
        }
        if [[ "$actual" != "$(
            /usr/libexec/PlistBuddy \
                -c "Print :$key" \
                "$extracted/BuildManifest.plist" 2>/dev/null
        )" ]]; then
            rm -rf "$extracted"
            release_error "Release and build manifests disagree about $key."
            return 1
        fi
    done
    actual="$(
        /usr/libexec/PlistBuddy \
            -c 'Print :Version' \
            "$extracted/BuildManifest.plist" 2>/dev/null
    )" || {
        rm -rf "$extracted"
        release_error "Build manifest has no version."
        return 1
    }
    [[ "$actual" == "$expected_version" ]] || {
        rm -rf "$extracted"
        release_error "Build manifest version differs from release evidence."
        return 1
    }
    actual="$(
        /usr/libexec/PlistBuddy \
            -c 'Print :BuildNumber' \
            "$extracted/BuildManifest.plist" 2>/dev/null
    )" || {
        rm -rf "$extracted"
        release_error "Build manifest has no build number."
        return 1
    }
    [[ "$actual" == "$expected_build" ]] || {
        rm -rf "$extracted"
        release_error "Build manifest number differs from release evidence."
        return 1
    }
    sdk_canonical_name="$(
        /usr/libexec/PlistBuddy \
            -c 'Print :SDKCanonicalName' \
            "$extracted/ReleaseManifest.plist" 2>/dev/null
    )" || {
        rm -rf "$extracted"
        release_error "Release evidence manifest has no SDK canonical name."
        return 1
    }
    sdk_settings_hash="$(
        /usr/libexec/PlistBuddy \
            -c 'Print :SDKSettingsSHA256' \
            "$extracted/ReleaseManifest.plist" 2>/dev/null
    )" || {
        rm -rf "$extracted"
        release_error "Release evidence manifest has no SDK settings hash."
        return 1
    }
    recorded_sdk_canonical_name="$(<"$extracted/sdk-version.txt")"
    recorded_sdk_settings_hash="$(<"$extracted/sdk-settings-sha256.txt")"
    recorded_sdk_path="$(<"$extracted/sdk-path.txt")"
    if [[ "$recorded_sdk_canonical_name" != "$sdk_canonical_name" ]] \
          || [[ "$recorded_sdk_settings_hash" != "$sdk_settings_hash" ]] \
          || ! matches_release_pattern \
              "$sdk_settings_hash" \
              '^[0-9a-f]{64}$' \
          || [[ "$recorded_sdk_path" != /* ]] \
          || [[ "$recorded_sdk_path" == *$'\n'* ]]; then
        rm -rf "$extracted"
        release_error "Recorded SDK evidence does not match the release manifest."
        return 1
    fi
    validate_notary_submission_result \
        "$extracted/app-notary-submission.json" || {
        rm -rf "$extracted"
        return 1
    }
    [[ "$REVIEWED_NOTARY_SUBMISSION_ID" == "$expected_app_submission_id" ]] || {
        rm -rf "$extracted"
        release_error "App notarization result belongs to another submission."
        return 1
    }
    validate_notary_log \
        "$extracted/app-notary-log.json" \
        "$expected_app_submission_id" \
        "$expected_app_submission_hash" \
        submission.zip || {
        rm -rf "$extracted"
        return 1
    }
    validate_notary_submission_result \
        "$extracted/dmg-notary-submission.json" || {
        rm -rf "$extracted"
        return 1
    }
    [[ "$REVIEWED_NOTARY_SUBMISSION_ID" == "$expected_dmg_submission_id" ]] || {
        rm -rf "$extracted"
        release_error "DMG notarization result belongs to another submission."
        return 1
    }
    validate_notary_log \
        "$extracted/dmg-notary-log.json" \
        "$expected_dmg_submission_id" \
        "$expected_dmg_submission_hash" \
        final.dmg || {
        rm -rf "$extracted"
        return 1
    }
    rm -rf "$extracted"
}
